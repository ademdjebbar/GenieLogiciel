@startuml DiagrammeCasUtilisation_Partie1
skinparam dpi 200
skinparam defaultFontSize 12
skinparam shadowing false
skinparam BackgroundColor #fef6fa
skinparam defaultFontColor #2d1f3d
left to right direction

skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #cdb4db
  FontColor #2d1f3d
  ArrowColor #cdb4db
  StereotypeFontColor #a2d2ff
}

skinparam actor {
  BorderColor #ffafcc
  FontColor #ffafcc
  BackgroundColor #FFFFFF
}

skinparam package {
  BackgroundColor #fff5f9
  BorderColor #cdb4db
  FontColor #ffafcc
  FontStyle bold
}

skinparam rectangle {
  BackgroundColor #fff5f9
  BorderColor #ffafcc
  FontColor #ffafcc
  RoundCorner 10
}

skinparam arrow {
  Color #cdb4db
  FontColor #7a6188
}

title <color:#ffafcc><b>Cas d'Utilisation (1/2)</b></color> - <color:#2d1f3d>Priora</color>\n<color:#7a6188>Authentification, Taches & Preferences</color>

actor "Utilisateur" as user

rectangle "Priora" {

  package "Authentification" {
    usecase "S'inscrire" as UC1
    usecase "Se connecter" as UC2
    usecase "Consulter son profil" as UC3
  }

  package "Gestion des Taches" {
    usecase "Creer une tache" as UC4
    usecase "Modifier une tache" as UC5
    usecase "Supprimer une tache" as UC6
    usecase "Changer le statut\nd'une tache" as UC7
    usecase "Lister ses taches" as UC8
    usecase "Filtrer par statut\nou categorie" as UC9
  }

  package "Preferences" {
    usecase "Consulter ses\npreferences" as UC15
    usecase "Modifier ses\npreferences" as UC16
  }
}

' --- Liens Utilisateur ---
user --> UC1
user --> UC2
user --> UC3
user --> UC4
user --> UC5
user --> UC6
user --> UC7
user --> UC8
user --> UC15
user --> UC16

' --- Relations entre cas ---
UC9 .> UC8 : <<extend>>
UC7 .> UC5 : <<include>>

@enduml
